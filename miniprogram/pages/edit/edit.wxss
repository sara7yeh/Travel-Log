.form-page{padding:30rpx 28rpx 90rpx}.form-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28rpx}.form-header image{width:150rpx;height:120rpx}.eyebrow{display:block;color:#bf5545;font-size:20rpx;font-weight:700}.title{display:block;font-size:43rpx;font-weight:900}.media-picker{display:flex;min-height:170rpx;flex-direction:column;align-items:center;justify-content:center;background:#fff;border:2rpx dashed #d9cbc1;color:#655e59}.plus{font-size:50rpx;color:#ed755f}.optional{margin-top:5rpx;color:#99918b;font-size:20rpx}.media-strip{margin:18rpx 0;white-space:nowrap}.media-item{position:relative;display:inline-block;width:230rpx;height:230rpx;margin-right:14rpx}.media-item image,.media-item video{width:100%;height:100%;border-radius:6rpx}.media-item button{position:absolute;top:8rpx;right:8rpx;width:50rpx;height:50rpx;line-height:44rpx;padding:0;background:rgba(30,26,24,.75);color:#fff;border-radius:50%}.field{margin-top:26rpx}.field>text{display:block;margin-bottom:10rpx;font-size:25rpx;font-weight:650}.field b{color:#e65f4c}.field input,.field textarea{box-sizing:border-box;width:100%;padding:22rpx;background:#fff;border:1px solid #ded5ce;border-radius:6rpx;font-size:26rpx}.field textarea{height:170rpx}.field small{display:block;margin-top:8rpx;color:#948b84;font-size:19rpx}.save{margin-top:40rpx}
.field-label{display:block;margin-bottom:10rpx;font-size:25rpx;font-weight:650}.required{color:#e65f4c}.field .help{display:block;margin-top:8rpx;color:#948b84;font-size:19rpx;font-weight:400}
