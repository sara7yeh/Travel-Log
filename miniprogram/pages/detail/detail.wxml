<view class="detail" wx:if="{{plan}}">
  <view class="detail-head"><view><text class="status">{{plan.status === 'planned' ? '想拍企划' : '已拍作品'}}</text><text class="title">{{plan.theme}}</text><text class="concept" wx:if="{{plan.concept}}">{{plan.concept}}</text></view><image src="{{plan.status === 'planned' ? '/assets/cat-planning.png' : '/assets/cat-happy.png'}}" mode="aspectFit"/></view>
  <view class="actions"><button class="ghost-button" bindtap="edit">编辑</button><button class="primary-button" bindtap="changeStatus">{{plan.status === 'planned' ? '标记已拍' : '移回想拍'}}</button></view>

  <view class="block"><text class="block-title">参考照片与视频</text><view class="media-grid" wx:if="{{plan.referenceMedia.length}}"><view class="media" wx:for="{{plan.referenceMedia}}" wx:key="path"><image wx:if="{{item.type === 'image'}}" src="{{item.path}}" mode="aspectFill" data-source="referenceMedia" data-path="{{item.path}}" bindtap="previewImage"/><video wx:else src="{{item.path}}" controls/></view></view><view class="blank" wx:else><image src="/assets/cat-camera.png" mode="aspectFit"/><text>这个企划还没有参考素材</text></view></view>

  <view class="block"><view class="block-row"><text class="block-title">我的已拍作品</text><button class="ghost-button add-work" bindtap="addResult">＋ 添加</button></view><view class="media-grid" wx:if="{{plan.resultMedia.length}}"><view class="media" wx:for="{{plan.resultMedia}}" wx:key="path"><image wx:if="{{item.type === 'image'}}" src="{{item.path}}" mode="aspectFill" data-source="resultMedia" data-path="{{item.path}}" bindtap="previewImage"/><video wx:else src="{{item.path}}" controls/><button class="remove" data-index="{{index}}" catchtap="removeResult">×</button></view></view><view class="blank" wx:else bindtap="addResult"><image src="/assets/cat-winter.png" mode="aspectFit"/><text>拍好后，把照片和视频放进这里</text></view></view>

  <view class="block details"><text class="block-title">企划笔记</text><view wx:if="{{plan.outfitTags.length}}"><text class="detail-label">衣服造型</text><view><text class="tag" wx:for="{{plan.outfitTags}}" wx:key="*this">{{item}}</text></view></view><view wx:if="{{plan.poseTags.length}}"><text class="detail-label">姿势构图</text><view><text class="tag" wx:for="{{plan.poseTags}}" wx:key="*this">{{item}}</text></view></view><view wx:if="{{plan.placeTypes.length}}"><text class="detail-label">适配地点</text><view><text class="tag" wx:for="{{plan.placeTypes}}" wx:key="*this">{{item}}</text></view></view><view wx:if="{{plan.specificPlace}}"><text class="detail-label">具体地点</text><text>{{plan.specificPlace}}</text></view><view wx:if="{{plan.note}}"><text class="detail-label">备注</text><text>{{plan.note}}</text></view><text class="muted" wx:if="{{!plan.outfitTags.length && !plan.poseTags.length && !plan.placeTypes.length && !plan.specificPlace && !plan.note}}">暂时没有其他笔记。</text></view>
  <button class="delete" bindtap="deletePlan">删除企划</button>
</view>
