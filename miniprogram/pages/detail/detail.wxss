.detail{padding:30rpx 26rpx 100rpx}.detail-head{display:flex;align-items:center;justify-content:space-between;padding:30rpx;background:#fff;border:1px solid #e2d9d2}.detail-head>view{max-width:70%}.detail-head image{width:190rpx;height:170rpx}.status{display:inline-block;padding:8rpx 14rpx;background:#fff0eb;color:#bd5141;border-radius:5rpx;font-size:21rpx}.title{display:block;margin-top:16rpx;font-size:45rpx;font-weight:900}.concept{display:block;margin-top:10rpx;color:#746c66;font-size:24rpx}.actions{display:flex;gap:14rpx;margin-top:18rpx}.actions button{flex:1;margin:0}.block{margin-top:34rpx}.block-title{display:block;margin-bottom:16rpx;font-size:31rpx;font-weight:850}.block-row{display:flex;align-items:center;justify-content:space-between}.add-work{width:auto;height:62rpx;line-height:62rpx;margin:0;padding:0 20rpx;font-size:22rpx}.media-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.media{position:relative;height:310rpx;background:#eee}.media image,.media video{width:100%;height:100%}.remove{position:absolute;top:9rpx;right:9rpx;width:52rpx;height:52rpx;line-height:44rpx;padding:0;background:rgba(30,26,24,.75);color:#fff;border-radius:50%}.blank{display:flex;min-height:250rpx;flex-direction:column;align-items:center;justify-content:center;background:#fff;border:2rpx dashed #ddd1c8;color:#7a726c}.blank image{width:150rpx;height:140rpx}.details{padding:28rpx;background:#fff;border:1px solid #e2d9d2}.details>view{margin-top:22rpx}.details b{display:block;margin-bottom:10rpx;font-size:23rpx}.details .tag{display:inline-block;margin:0 8rpx 8rpx 0}.details>view>text:not(.tag){color:#716962;font-size:24rpx}.muted{color:#8c837d}.delete{margin-top:48rpx;background:transparent;color:#c04f42;font-size:24rpx}.delete:after{border-color:#dfb2aa}
.details .detail-label{display:block;margin-bottom:10rpx;font-size:23rpx;font-weight:700}
